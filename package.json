{
  "name": "playwright-automationexercise",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright POM + API tests for automationexercise.com (UI flows and REST API list).",
  "scripts": {
    "test": "playwright test",
    "test:api": "playwright test --project=api",
    "test:ui": "playwright test --project=chromium",
    "test:headed": "playwright test --project=chromium --headed",
    "test:sanity": "playwright test --grep @sanity",
    "test:report": "playwright test --config=playwright.report.config.ts",
    "report:open": "playwright show-report",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@types/node": "^22.13.10",
    "dotenv": "^16.4.7",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2"
  }
}
